    {
      "name": "Weather",
      "item": [
        {
          "name": "Current Weather",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('current weather contains the requested location', function () {",
                  "  pm.expect(body.data.location).to.eql(pm.variables.get('location'));",
                  "});",
                  "",
                  "pm.test('current weather includes condition and temperature', function () {",
                  "  pm.expect(body.data.condition).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.temperatureC).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "url": "{{baseUrl}}/weather/current?location={{location}}"
          }
        },
        {
          "name": "Premium Forecast",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('premium forecast returns seven entries', function () {",
                  "  pm.expect(body.data).to.be.an('array').with.lengthOf(7);",
                  "});",
                  "",
                  "pm.test('forecast entries match the requested location', function () {",
                  "  body.data.forEach((entry) => pm.expect(entry.location).to.eql(pm.variables.get('location')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "url": "{{baseUrl}}/weather/premium-forecast?location={{location}}"
          }
        },
