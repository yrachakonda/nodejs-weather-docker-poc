    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "const generatedUsername = `newuser-${runId}`;",
                  "const generatedPassword = `newuser-pass-${runId}`;",
                  "pm.collectionVariables.set('generatedUsername', generatedUsername);",
                  "pm.collectionVariables.set('generatedPassword', generatedPassword);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const expectedUsername = pm.collectionVariables.get('generatedUsername');",
                  "pm.test('registered username matches generated username', function () {",
                  "  pm.expect(body.user.username).to.eql(expectedUsername);",
                  "});",
                  "",
                  "pm.test('registered role defaults to basic', function () {",
                  "  pm.expect(body.user.role).to.eql('basic');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{generatedUsername}}\",\n  \"password\": \"{{generatedPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const requestedUsername = pm.variables.get('username') || 'premiumuser';",
                  "let resolvedPassword = pm.variables.get('password');",
                  "",
                  "if (!resolvedPassword) {",
                  "  if (requestedUsername === 'premiumuser') {",
                  "    resolvedPassword = 'premium-pass';",
                  "  } else if (requestedUsername === 'basicuser') {",
                  "    resolvedPassword = 'basic-pass';",
                  "  } else if (requestedUsername === 'admin') {",
                  "    resolvedPassword = 'admin-pass';",
                  "  }",
                  "}",
                  "",
                  "pm.variables.set('loginUsername', requestedUsername);",
                  "pm.variables.set('loginPassword', resolvedPassword || '');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const expectedUsername = pm.variables.get('loginUsername');",
                  "pm.collectionVariables.set('lastLoggedInUsername', body.user.username);",
                  "",
                  "pm.test('logged-in user matches requested username', function () {",
                  "  pm.expect(body.user.username).to.eql(expectedUsername);",
                  "});",
                  "",
                  "pm.test('logged-in user includes a role', function () {",
                  "  pm.expect(body.user.role).to.be.oneOf(['basic', 'premium', 'admin']);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{loginUsername}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('me returns the logged-in user', function () {",
                  "  pm.expect(body.user.username).to.eql(pm.collectionVariables.get('lastLoggedInUsername'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 204', function () {",
