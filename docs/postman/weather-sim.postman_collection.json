    {
      "name": "Weather",
      "item": [
        {
          "name": "Current Weather",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resolvedApiKey = pm.variables.get('apiKey') || 'poc-premium-key-001';",
                  "const resolvedLocation = (pm.variables.get('location') || 'seattle').trim() || 'seattle';",
                  "pm.variables.set('resolvedApiKey', resolvedApiKey);",
                  "pm.variables.set('resolvedLocation', resolvedLocation);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const expectedLocation = pm.variables.get('resolvedLocation');",
                  "pm.test('current weather contains the requested location', function () {",
                  "  pm.expect(body.data.location).to.eql(expectedLocation);",
                  "});",
                  "",
                  "pm.test('current weather includes condition and temperature', function () {",
                  "  pm.expect(body.data.condition).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.temperatureC).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{resolvedApiKey}}"
              }
            ],
            "url": "{{baseUrl}}/weather/current?location={{resolvedLocation}}"
          }
        },
        {
          "name": "Premium Forecast",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resolvedApiKey = pm.variables.get('apiKey') || 'poc-premium-key-001';",
                  "const resolvedLocation = (pm.variables.get('location') || 'seattle').trim() || 'seattle';",
                  "pm.variables.set('resolvedApiKey', resolvedApiKey);",
                  "pm.variables.set('resolvedLocation', resolvedLocation);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const expectedLocation = pm.variables.get('resolvedLocation');",
                  "pm.test('premium forecast returns seven entries', function () {",
                  "  pm.expect(body.data).to.be.an('array').with.lengthOf(7);",
                  "});",
                  "",
                  "pm.test('forecast entries match the requested location', function () {",
                  "  body.data.forEach((entry) => pm.expect(entry.location).to.eql(expectedLocation));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{resolvedApiKey}}"
              }
            ],
            "url": "{{baseUrl}}/weather/premium-forecast?location={{resolvedLocation}}"
          }
        },
        {
